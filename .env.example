OPENAI_API_KEY=your_api_key_here
FRONTEND_ORIGINS=http://localhost:3000

# 운영 환경(Vercel)에서 로컬 SQLite 대신 아무 저장소도 쓰지 않게 하려면 production으로.
# Vercel은 VERCEL=1을 자동으로 설정하므로 보통 직접 지정할 필요 없음.
APP_ENV=development

# 아임웹 Open API가 게시판 글쓰기를 지원하지 않아, 생성 결과를 복사해 이 페이지에
# 직접 붙여넣도록 안내하는 용도. 지점의 실제 게시판 글쓰기 페이지 URL로 설정.
IMWEB_BOARD_WRITE_URL=https://your-store.imweb.me/board/12/write
